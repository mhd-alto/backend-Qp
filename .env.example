NODE_ENV=development
PORT=3000
API_PREFIX=api
APP_NAME=copoun-api
APP_VERSION=1.0.0
DEFAULT_LOCALE=ar
SUPPORTED_LOCALES=ar,en
ALLOWED_ORIGINS=http://localhost:3000
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_TTL=30d
PASSWORD_RESET_TTL=15m

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=12345
DATABASE_NAME=copoun
DATABASE_SSL=false
DATABASE_MIGRATIONS_RUN=true
DATABASE_LOGGING=false
SWAGGER_ENABLED=true
SWAGGER_PATH=api/docs
SWAGGER_DESCRIPTION=CouponHub Syria MVP API documentation
MEDIA_DRIVER=local
MEDIA_LOCAL_PATH=uploads
MEDIA_PUBLIC_BASE_URL=

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=12345
DB_NAME=copoun

# Feature Flags Configuration
FEATURE_CAMPAIGN_COPILOT=false
FEATURE_SMART_SEARCH=false
FEATURE_TRUST_SHIELD=false
FEATURE_IMPACT_METRICS=false
FEATURE_OFFLINE_REDEMPTION=false

# External APIs
GEMINI_API_KEY=

